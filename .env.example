LLM_PROVIDER_MODE=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Doubao (ByteDance) Streaming ASR — optional
# Set ASR_PROVIDER_MODE=doubao to enable real-time Chinese-English mixed recognition.
# Leave blank (or set to anything other than "doubao") to use browser SpeechRecognition fallback.
# Get credentials from the Volcano Engine console: https://console.volcengine.com/speech/service/8
ASR_PROVIDER_MODE=browser
DOUBAO_APP_ID=
DOUBAO_ASR_TOKEN=
# Resource ID for the BigModel ASR endpoint (接入点/模型版本ID).
# Get from: 火山引擎控制台 → 语音技术 → 大模型流式识别 → 接入管理 → 新建接入点
DOUBAO_RESOURCE_ID=
