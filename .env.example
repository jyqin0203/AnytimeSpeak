LLM_PROVIDER_MODE=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Doubao (ByteDance) BigModel Streaming ASR - optional
# Set ASR_PROVIDER_MODE=doubao to enable real-time Chinese-English mixed recognition.
# Leave blank (or set to anything other than "doubao") to use browser SpeechRecognition fallback.
# New console: fill DOUBAO_API_KEY and DOUBAO_RESOURCE_ID.
# Legacy console: fill DOUBAO_APP_ID, DOUBAO_ASR_TOKEN, and DOUBAO_RESOURCE_ID.
ASR_PROVIDER_MODE=browser
DOUBAO_API_KEY=
DOUBAO_APP_ID=
DOUBAO_ASR_TOKEN=
# Examples: volc.bigasr.sauc.duration (Doubao 1.0) or volc.seedasr.sauc.duration (Doubao 2.0).
DOUBAO_RESOURCE_ID=
# Optional endpoint. Defaults to the recommended async bidirectional streaming API.
# Other choices:
#   wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
#   wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
DOUBAO_ASR_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
# Optional: full returns the full transcript each time; single returns incremental text.
DOUBAO_RESULT_TYPE=full
